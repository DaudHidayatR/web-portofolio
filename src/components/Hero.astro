---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getIcon } from "../utils/iconMapper";
import { parseInlineLinks } from "../utils/parseInlineLinks";

interface Props {
	hero: {
		name: string;
		title: string;
		description: string;
		avatar: ImageMetadata | string;
		location?: string;
		socialLinks: Array<{
			url: string;
			icon: string;
			label: string;
		}>;
	};
}

const { hero } = Astro.props;
---

<section class="hero min-h-[calc(100svh-4rem)] py-16 px-4 sm:min-h-screen sm:py-20">
  <div class="hero-content flex-col lg:flex-row-reverse max-w-7xl gap-8 lg:gap-16 px-0">
    <div class="hover-3d">
      <!-- content -->
      <figure class="max-w-100 w-40 sm:w-48 lg:w-64 aspect-square overflow-hidden mask mask-squircle">
        {
          typeof hero.avatar === "string" ? (
            <img src={hero.avatar} alt={hero.name} class="h-full w-full object-cover object-top" />
          ) : (
            <Image src={hero.avatar} alt={hero.name} class="h-full w-full object-cover object-top" loading="eager" decoding="async" />
          )
        }
      </figure>
      <!-- 8 empty divs needed for the 3D effect -->
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
    </div>
    <div class="max-w-2xl text-center lg:text-left">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-balance">
        Hi, I'm {hero.name}
      </h1>
      <p class="skeleton skeleton-text text-xl text-base-content/80 mb-2" set:html={parseInlineLinks(hero.title)} />
      {
        hero.location && (
          <p class="text-base-content/60 mb-4">{hero.location}</p>
        )
      }
      <p class="text-base sm:text-lg leading-relaxed mb-6" set:html={parseInlineLinks(hero.description)} />
      <div
        class="grid grid-cols-4 gap-2 justify-items-center lg:flex lg:gap-4 lg:justify-start"
      >
        {
          hero.socialLinks.map((link) => {
            const IconComponent = getIcon(link.icon as any);
            return (
              <div class="tooltip tooltip-top" data-tip={link.label}>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-circle btn-primary lg:btn-ghost"
                  aria-label={link.label}
                >
                  <IconComponent class="size-6" />
                </a>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
