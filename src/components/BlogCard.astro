---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
	post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

function formatDate(date: Date) {
	const options: Intl.DateTimeFormatOptions = {
		month: "long",
		day: "numeric",
		year: "numeric",
	};
	return date.toLocaleDateString("en-US", options);
}
---

<article class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow overflow-hidden">
  <figure class="aspect-video bg-base-200">
    <Image
      src={post.data.image}
      alt={post.data.title}
      class="h-full w-full object-cover"
    />
  </figure>
  <div class="card-body">
    <time class="text-sm text-base-content/60">
      {formatDate(post.data.publishDate)}
    </time>
    <h3 class="card-title hover:text-primary transition-colors">
      <a href={`/blog/${post.id}`}>{post.data.title}</a>
    </h3>
    <p class="text-base-content/80 line-clamp-3">{post.data.description}</p>
    <div class="card-actions justify-end mt-4">
      <a href={`/blog/${post.id}`} class="btn btn-primary btn-sm">Read More</a>
    </div>
  </div>
</article>
