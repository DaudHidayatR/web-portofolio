---
import type { CollectionEntry } from "astro:content";
/**
 * ProjectsLayoutSidebar
 * Renders projects with a DaisyUI menu sidebar on the left.
 * Each category is a menu item; clicking it shows its projects on the right.
 * Uses client-side JS to toggle visibility.
 */
import ProjectCard from "./ProjectCard.astro";

interface CategoryGroup {
	slug: string;
	title: string;
	description?: string;
	icon?: string;
	projects: CollectionEntry<"projects">[];
}

interface Props {
	categoryGroups: CategoryGroup[];
	uncategorizedProjects: CollectionEntry<"projects">[];
}

const { categoryGroups, uncategorizedProjects } = Astro.props;

const allProjects = [
	...categoryGroups.flatMap((group) => group.projects),
	...uncategorizedProjects,
].sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const getProjectCategoryLabel = (
	project: CollectionEntry<"projects">,
	tabSlug: string,
) => {
	if (tabSlug === "_all") {
		return categoryGroups.find((group) => group.slug === project.data.category)
			?.title;
	}

	return tabSlug !== "_other"
		? categoryGroups.find((group) => group.slug === tabSlug)?.title
		: undefined;
};

// Merge all projects, categorized projects, and uncategorized projects into the tab list
const allTabs = [
	{
		slug: "_all",
		title: "All Projects",
		description:
			"Every project in one place, across DevSecOps, backend, cloud, security, and other work.",
		icon: "🗂️",
		projects: allProjects,
	},
	...categoryGroups,
	...(uncategorizedProjects.length > 0
		? [
				{
					slug: "_other",
					title: "Other",
					description: "Projects not assigned to a category.",
					icon: "📁",
					projects: uncategorizedProjects,
				},
			]
		: []),
];
---

<div class="flex flex-col lg:flex-row gap-6">
  <!-- Sidebar Menu -->
  <ul class="menu bg-base-200 rounded-box w-full lg:w-64 shrink-0">
    <li class="menu-title">Categories</li>
    {allTabs.map((tab, index) => (
      <li>
        <button
          class:list={["sidebar-tab-btn", { "active bg-primary text-primary-content": index === 0 }]}
          data-target={`panel-${tab.slug}`}
        >
          {tab.icon && <span>{tab.icon}</span>}
          {tab.title}
          <span class="badge badge-sm badge-ghost">{tab.projects.length}</span>
        </button>
      </li>
    ))}
  </ul>

  <!-- Content Panels -->
  <div class="flex-1 min-w-0">
    {allTabs.map((tab, index) => (
      <div
        id={`panel-${tab.slug}`}
        class:list={["sidebar-tab-panel", { hidden: index !== 0 }]}
      >
        <h3 class="text-2xl font-bold mb-1">
          {tab.icon && <span class="mr-2">{tab.icon}</span>}
          {tab.title}
        </h3>
        {tab.description && (
          <p class="text-base-content/60 mb-6">{tab.description}</p>
        )}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {tab.projects.map((project) => (
            <ProjectCard
              project={project}
              categoryLabel={getProjectCategoryLabel(project, tab.slug)}
            />
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".sidebar-tab-btn");
    const panels = document.querySelectorAll<HTMLDivElement>(".sidebar-tab-panel");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.target;

        // Toggle active state on buttons
        buttons.forEach((b) => {
          b.classList.remove("active", "bg-primary", "text-primary-content");
        });
        btn.classList.add("active", "bg-primary", "text-primary-content");

        // Toggle panel visibility
        panels.forEach((p) => {
          if (p.id === target) {
            p.classList.remove("hidden");
          } else {
            p.classList.add("hidden");
          }
        });
      });
    });
  });
</script>

