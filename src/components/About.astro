---
import { Image } from "astro:assets";
import { ExternalLink } from "@lucide/astro";
import type { ImageMetadata } from "astro";

interface Props {
	title: string;
	photo?: ImageMetadata | string;
	Content: any;
	link?: string;
}

const { title, photo, Content, link } = Astro.props;
const photoAlt = "Daud Hidayat Ramadhan, DevSecOps and Backend Engineer";
---

<section id="about" class="py-12 sm:py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="card bg-base-200 shadow-sm overflow-hidden lg:card-side">
      {
        photo && (
          <figure class="bg-base-300 lg:w-80 lg:shrink-0">
            {typeof photo === "string" ? (
              <img
                src={photo}
                alt={photoAlt}
                class="h-72 w-full object-cover object-top lg:h-full"
              />
            ) : (
              <Image
                src={photo}
                alt={photoAlt}
                class="h-72 w-full object-cover object-top lg:h-full"
                width={480}
                height={720}
                loading="lazy"
                decoding="async"
              />
            )}
          </figure>
        )
      }
      <div class="card-body p-6 sm:p-8 lg:p-10">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">
          About
        </p>
        <h2 class="card-title text-3xl sm:text-4xl">{title}</h2>
        <article
          class="prose prose-sm sm:prose-base max-w-3xl prose-a:text-primary prose-a:underline prose-a:hover:opacity-80"
        >
          <Content />
        </article>
        {
          link && (
            <div class="card-actions justify-start mt-2">
              <a
                href={link}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-outline gap-2"
                aria-label="More about me on LinkedIn"
              >
                More about me
                <ExternalLink class="size-4" />
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
