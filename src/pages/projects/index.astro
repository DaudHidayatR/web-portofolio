---
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry } from "astro:content";
import ProjectsLayoutGrid from "../../components/ProjectsLayoutGrid.astro";
import ProjectsLayoutTabsHorizontal from "../../components/ProjectsLayoutTabsHorizontal.astro";
import ProjectsLayoutTabsVertical from "../../components/ProjectsLayoutTabsVertical.astro";
import Layout from "../../layouts/Layout.astro";

const projects = await getCollection("projects");
const categories = await getCollection("projectCategories");

// Load General settings for layout preference
const generalEntry = await getEntry("general", "index");
const projectsLayout = generalEntry?.data?.projectsLayout ?? "grid";

// Sort categories by sortOrder, then alphabetically
const sortedCategories = categories.sort((a, b) => {
	const orderA = a.data.sortOrder ?? 0;
	const orderB = b.data.sortOrder ?? 0;
	if (orderA !== orderB) return orderA - orderB;
	return a.data.title.localeCompare(b.data.title);
});

// Build a map of category slug -> category data
const categoryMap = new Map(sortedCategories.map((cat) => [cat.id, cat.data]));

// Build category groups
interface CategoryGroup {
	slug: string;
	title: string;
	description?: string;
	icon?: string;
	projects: CollectionEntry<"projects">[];
}

const categoryGroups: CategoryGroup[] = [];

for (const cat of sortedCategories) {
	const catProjects = projects
		.filter((p) => p.data.category === cat.id)
		.sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

	if (catProjects.length > 0) {
		categoryGroups.push({
			slug: cat.id,
			title: cat.data.title,
			description: cat.data.description,
			icon: cat.data.icon,
			projects: catProjects,
		});
	}
}

// Uncategorized projects
const uncategorizedProjects = projects
	.filter((p) => !p.data.category || !categoryMap.has(p.data.category))
	.sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---

<Layout
  title="DevSecOps & Backend Projects | Daud Hidayat Ramadhan"
  description="DevSecOps and backend project case studies by Daud Hidayat Ramadhan, including Secure SDLC pipelines, Kubernetes labs, security scanning, and automation."
>
  <main class="max-w-6xl mx-auto px-4 py-16 sm:py-20">
    <!-- Header -->
    <div class="text-center mb-10 sm:mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">DevSecOps & Backend Projects</h1>
      <p class="text-lg sm:text-xl text-base-content/70 max-w-3xl mx-auto">
        Case studies and labs that show how I approach Secure SDLC, CI/CD
        security, backend services, Kubernetes, and practical automation.
      </p>
    </div>

    <!-- Back to Home -->
    <div class="mb-8">
      <a href="/" class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Home
      </a>
    </div>

    {
      projects.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-2xl text-base-content/60">
            No projects yet. Check back soon!
          </p>
        </div>
      ) : projectsLayout === "tabs-horizontal" ? (
        <ProjectsLayoutTabsHorizontal
          categoryGroups={categoryGroups}
          uncategorizedProjects={uncategorizedProjects}
        />
      ) : projectsLayout === "tabs-vertical" ? (
        <ProjectsLayoutTabsVertical
          categoryGroups={categoryGroups}
          uncategorizedProjects={uncategorizedProjects}
        />
      ) : (
        <ProjectsLayoutGrid
          categoryGroups={categoryGroups}
          uncategorizedProjects={uncategorizedProjects}
        />
      )
    }
  </main>
</Layout>
