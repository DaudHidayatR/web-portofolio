---
import "../styles/global.css";
import { getEntry } from "astro:content";
import Dock from "../components/Dock.astro";
import FabFlower from "../components/FabFlower.astro";
import ThemeController from "../components/ThemeController.svelte";

// Load general singleton
const generalEntry = await getEntry("general", "index");
const general = generalEntry.data;

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogImageWidth?: number;
	ogImageHeight?: number;
	robots?: string;
}

const {
	title = "Daud Hidayat Ramadhan | DevSecOps & Backend Engineer",
	description = "DevSecOps and Backend Engineering portfolio covering Secure SDLC, CI/CD security, REST APIs, Kubernetes, and automation.",
	ogImage,
	ogImageAlt,
	ogImageWidth,
	ogImageHeight,
	robots = "index, follow",
} = Astro.props;

const origin = Astro.site?.origin ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, origin);
const isDefaultOgImage = !ogImage;
const ogImageUrl = ogImage ?? new URL("/images/og_home.png", origin).href;
const resolvedOgImageAlt =
	ogImageAlt ??
	(isDefaultOgImage ? "Portrait of Daud Hidayat Ramadhan" : description);
const resolvedOgImageWidth =
	ogImageWidth ?? (isDefaultOgImage ? 1200 : undefined);
const resolvedOgImageHeight =
	ogImageHeight ?? (isDefaultOgImage ? 630 : undefined);
const personJsonLd = {
	"@type": "Person",
	"@id": `${origin}/#person`,
	name: "Daud Hidayat Ramadhan",
	url: origin,
	email: "mailto:me@daudhr.com",
	jobTitle: "DevSecOps & Backend Engineer",
	nationality: "Indonesian",
	alumniOf: {
		"@type": "CollegeOrUniversity",
		name: "Universitas Islam Indonesia",
	},
	sameAs: [
		"https://github.com/DaudHidayatR",
		"https://www.linkedin.com/in/daud-hidayat-ramadhan",
	],
	knowsAbout: [
		"DevSecOps",
		"Secure SDLC",
		"CI/CD Security",
		"Backend Engineering",
		"REST API Security",
		"Go",
		"PHP",
		"Laravel",
		"Kubernetes",
		"OpenBao",
		"SAST",
		"Dependency Scanning",
		"Secret Scanning",
	],
};
const siteJsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		personJsonLd,
		{
			"@type": "WebSite",
			"@id": `${origin}/#website`,
			url: origin,
			name: "Daud Hidayat Ramadhan Portfolio",
			description,
			publisher: { "@id": `${origin}/#person` },
			inLanguage: "en",
		},
		{
			"@type": "ProfilePage",
			"@id": `${canonicalUrl.href}#profile`,
			url: canonicalUrl.href,
			name: title,
			description,
			isPartOf: { "@id": `${origin}/#website` },
			about: { "@id": `${origin}/#person` },
			primaryImageOfPage: ogImageUrl,
			inLanguage: "en",
		},
	],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-48x48.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      const theme = localStorage.getItem("theme") || document.documentElement.getAttribute("data-theme") || "dim";
      document.documentElement.setAttribute("data-theme", theme);
    </script>
    <!-- Google Analytics is loaded after the page becomes interactive to avoid competing with LCP on mobile. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      const loadAnalytics = () => {
        if (document.querySelector('script[data-analytics="gtag"]')) return;

        const script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-67YE3ZCP1V';
        script.dataset.analytics = 'gtag';
        script.onload = () => {
          gtag('js', new Date());
          gtag('config', 'G-67YE3ZCP1V');
        };
        document.head.appendChild(script);
      };

      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadAnalytics, { timeout: 2500 });
      } else {
        window.addEventListener('load', () => setTimeout(loadAnalytics, 1500), { once: true });
      }
    </script>
    <title>{title}</title>

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    {resolvedOgImageWidth && <meta property="og:image:width" content={resolvedOgImageWidth} />}
    {resolvedOgImageHeight && <meta property="og:image:height" content={resolvedOgImageHeight} />}
    <meta property="og:site_name" content="Daud Hidayat Ramadhan" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    {resolvedOgImageWidth && <meta name="twitter:image:width" content={resolvedOgImageWidth} />}
    {resolvedOgImageHeight && <meta name="twitter:image:height" content={resolvedOgImageHeight} />}
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <!-- Theme Controls - Fixed Position -->
    <div class="fixed top-4 right-4 z-50">
      <ThemeController enableSelector={general.enableThemeSelector} client:load />
    </div>

    <slot />

    {
      general.extraLinksEnabled && (
        <>
          {/* FabFlower for desktop - show 'both' and 'fab' items */}
          <FabFlower
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "dock"
            )}
          />
          {/* Dock for mobile - show 'both' and 'dock' items */}
          <Dock
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "fab"
            )}
          />
        </>
      )
    }

    <!-- Smooth Scroll -->
    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      /* Initial Page Load Fade Animation */
      @keyframes pageLoadFade {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @media (prefers-reduced-motion: no-preference) {
        body {
          animation: pageLoadFade 0.2s ease-out;
          animation-fill-mode: both;
        }
      }
    </style>
  </body>
</html>
