---
import "../styles/global.css";
import { getEntry } from "astro:content";
import { ClientRouter } from "astro:transitions";
import Dock from "../components/Dock.astro";
import FabFlower from "../components/FabFlower.astro";
import ThemeSelector from "../components/ThemeSelector.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

// Load general singleton
const generalEntry = await getEntry("general", "index");
const general = generalEntry.data;

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = "Daud Hidayat Ramadhan — DevSecOps & Backend Engineer",
	description = "DevSecOps & Backend portfolio of Daud Hidayat Ramadhan, focused on Secure SDLC, CI/CD security, backend services, REST API security, Kubernetes, OpenBao, SAST, dependency scanning, and secret scanning.",
	ogImage,
} = Astro.props;

// Custom blur-fade animation configuration
const blurFadeAnimation = {
	old: {
		name: "blurFadeOut",
		duration: "0.3s",
		easing: "ease-in-out",
		fillMode: "forwards",
	},
	new: {
		name: "blurFadeIn",
		duration: "0.3s",
		easing: "ease-in-out",
		fillMode: "backwards",
	},
};

const pageTransition = {
	forwards: blurFadeAnimation,
	backwards: blurFadeAnimation,
};

const origin = Astro.site?.origin ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, origin);
const ogImageUrl = ogImage ?? new URL("/images/og_home.png", origin).href;
const siteJsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Daud Hidayat Ramadhan",
	url: origin,
	jobTitle: "DevSecOps & Backend Engineer",
	sameAs: [
		"https://github.com/DaudHidayatR",
		"https://www.linkedin.com/in/daud-hidayat-ramadhan",
	],
	knowsAbout: [
		"DevSecOps",
		"Secure SDLC",
		"CI/CD Security",
		"Backend Engineering",
		"REST API Security",
		"Go",
		"PHP",
		"Laravel",
		"Kubernetes",
		"OpenBao",
		"SAST",
		"Dependency Scanning",
		"Secret Scanning",
	],
};
---

<!doctype html>
<html lang="en" transition:animate={pageTransition}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title={`${title} RSS`} href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- View Transitions -->
    <ClientRouter />

    <!-- Open Graph / Social Media -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Daud Hidayat Ramadhan" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <!-- Theme Controls - Fixed Position -->
    <div class="fixed top-4 right-4 z-50">
      {general.enableThemeSelector ? <ThemeSelector /> : <ThemeToggle />}
    </div>

    <slot />

    {
      general.extraLinksEnabled && (
        <>
          {/* FabFlower for desktop - show 'both' and 'fab' items */}
          <FabFlower
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "dock"
            )}
          />
          {/* Dock for mobile - show 'both' and 'dock' items */}
          <Dock
            extraLinks={general.extraLinks.filter(
              (link) => link.displayOn !== "fab"
            )}
          />
        </>
      )
    }

    <!-- Smooth Scroll -->
    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      /* Initial Page Load Blur-Fade Animation */
      @keyframes pageLoadBlurFade {
        0% {
          opacity: 0;
          filter: blur(8px);
        }
        100% {
          opacity: 1;
          filter: blur(0px);
        }
      }

      html {
        animation: pageLoadBlurFade 0.3s ease-in-out;
        animation-fill-mode: both;
      }

      /* Blur Fade View Transitions (for page-to-page navigation) */
      @keyframes blurFadeIn {
        0% {
          opacity: 0;
          filter: blur(10px);
        }
        100% {
          opacity: 1;
          filter: blur(0px);
        }
      }

      @keyframes blurFadeOut {
        0% {
          opacity: 1;
          filter: blur(0px);
        }
        100% {
          opacity: 0;
          filter: blur(10px);
        }
      }
    </style>
  </body>
</html>
