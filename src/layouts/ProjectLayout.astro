---
import { Image } from "astro:assets";
import { ExternalLink } from "@lucide/astro";
import SkillBadge from "../components/SkillBadge.astro";
import Layout from "./Layout.astro";

interface Props {
	title: string;
	description: string;
	startDate: Date;
	endDate?: Date;
	image: any;
	imageAlt?: string;
	imageWidth?: number;
	imageHeight?: number;
	imageDisplay?: "cover" | "diagram";
	skills: string[];
	demoLink?: string;
	sourceLink?: string;
}

const {
	title,
	description,
	startDate,
	endDate,
	image,
	imageAlt,
	imageWidth,
	imageHeight,
	imageDisplay = "cover",
	skills,
	demoLink,
	sourceLink,
} = Astro.props;

function formatPeriod(startDate: Date, endDate?: Date) {
	const options: Intl.DateTimeFormatOptions = {
		month: "short",
		year: "numeric",
	};
	const start = startDate.toLocaleDateString("en-US", options);
	const end = endDate
		? endDate.toLocaleDateString("en-US", options)
		: "Present";
	return `${start} - ${end}`;
}

// Calculate project duration
function calculateDuration(startDate: Date, endDate?: Date) {
	const end = endDate || new Date();
	const months =
		(end.getFullYear() - startDate.getFullYear()) * 12 +
		(end.getMonth() - startDate.getMonth());

	if (months < 1) return "Less than a month";
	if (months === 1) return "1 month";
	if (months < 12) return `${months} months`;

	const years = Math.floor(months / 12);
	const remainingMonths = months % 12;

	if (remainingMonths === 0) return years === 1 ? "1 year" : `${years} years`;
	return `${years} year${years > 1 ? "s" : ""}, ${remainingMonths} month${remainingMonths > 1 ? "s" : ""}`;
}

// OG image URL for per-page social sharing
const origin = Astro.site?.origin ?? Astro.url.origin;
const ogImageUrl = image ? new URL(image.src, origin).href : undefined;
const projectImageAlt = imageAlt ?? `${title} project architecture`;
const projectImageWidth = imageWidth ?? image?.width;
const projectImageHeight = imageHeight ?? image?.height;
const isDiagramImage = imageDisplay === "diagram";
const canonicalUrl = new URL(Astro.url.pathname, origin).href;
const projectKeywords = skills ?? [];
const seoTitleMap: Record<string, string> = {
	"DevSecOps Security Scanning Pipeline":
		"DevSecOps Security Scanning Pipeline | Secure SDLC Project",
	"Self-Hosted DevSecOps Lab":
		"Self-Hosted DevSecOps Lab | Kubernetes Security Portfolio",
	"Linux Security Audit Automation":
		"Linux Security Audit Automation | Host Hardening Project",
};
const seoTitle = seoTitleMap[title] ?? `${title} | DevSecOps Project`;
const languageMap: Record<string, string[]> = {
	"DevSecOps Security Scanning Pipeline": ["Shell", "YAML"],
	"Self-Hosted DevSecOps Lab": ["YAML", "Shell"],
	"Linux Security Audit Automation": ["Shell", "Python"],
};
const programmingLanguage = languageMap[title] ?? skills;
const projectJsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": `${canonicalUrl}#webpage`,
			url: canonicalUrl,
			name: title,
			description,
			image: ogImageUrl,
			primaryImageOfPage: ogImageUrl
				? {
						"@type": "ImageObject",
						url: ogImageUrl,
						contentUrl: ogImageUrl,
						caption: projectImageAlt,
						width: projectImageWidth,
						height: projectImageHeight,
						representativeOfPage: true,
					}
				: undefined,
			author: { "@id": `${origin}/#person` },
			about: { "@id": `${canonicalUrl}#software` },
		},
		{
			"@type": "SoftwareSourceCode",
			"@id": `${canonicalUrl}#software`,
			name: title,
			description,
			codeRepository: sourceLink,
			programmingLanguage,
			keywords: projectKeywords,
			dateCreated: startDate.toISOString().slice(0, 10),
			dateModified: (endDate ?? new Date()).toISOString().slice(0, 10),
			creator: { "@id": `${origin}/#person` },
		},
		{
			"@type": "Person",
			"@id": `${origin}/#person`,
			name: "Daud Hidayat Ramadhan",
			url: origin,
			jobTitle: "DevSecOps & Backend Engineer",
			sameAs: [
				"https://github.com/DaudHidayatR",
				"https://www.linkedin.com/in/daud-hidayat-ramadhan",
			],
		},
	],
};
---

<Layout
  title={seoTitle}
  description={description}
  ogImage={ogImageUrl}
  ogImageAlt={projectImageAlt}
  ogImageWidth={projectImageWidth}
  ogImageHeight={projectImageHeight}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(projectJsonLd)} />
  <article class="max-w-4xl mx-auto px-4 py-20">
    <!-- Back button -->
    <div class="mb-8">
      <a href="/projects" class="btn btn-ghost btn-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Projects
      </a>
    </div>

    <!-- Featured Image -->
    <!-- TODO: Future Enhancement - Support multiple images/project gallery -->
    {
      image && (
        <figure class="mb-8 rounded-2xl overflow-hidden bg-base-200">
          <button
            type="button"
            class="block w-full cursor-zoom-in"
            aria-label={`Zoom image: ${projectImageAlt}`}
            data-project-image-open
          >
            {isDiagramImage ? (
              <Image
                src={image}
                alt={projectImageAlt}
                class="h-auto w-full p-2"
                width={projectImageWidth ?? 1450}
                height={projectImageHeight ?? 494}
                loading="eager"
                decoding="async"
              />
            ) : (
              <Image
                src={image}
                alt={projectImageAlt}
                class="w-full aspect-video object-cover"
                width={projectImageWidth ?? 1200}
                height={projectImageHeight ?? 630}
                loading="eager"
                decoding="async"
              />
            )}
          </button>
        </figure>
      )
    }

    {
      image && (
        <dialog
          class="modal backdrop:bg-black/80"
          aria-label={`Zoomed image: ${projectImageAlt}`}
          data-project-image-dialog
        >
          <div class="modal-box max-w-[96vw] bg-base-100 p-3 shadow-2xl">
            <form method="dialog" class="mb-3 flex justify-end">
              <button class="btn btn-circle btn-sm" aria-label="Close image zoom">
                x
              </button>
            </form>
            <Image
              src={image}
              alt={projectImageAlt}
              class="max-h-[82vh] w-full rounded-xl object-contain"
              width={projectImageWidth ?? 1600}
              height={projectImageHeight ?? 900}
              loading="lazy"
              decoding="async"
            />
          </div>
          <form method="dialog" class="modal-backdrop">
            <button aria-label="Close image zoom">close</button>
          </form>
        </dialog>
      )
    }

    <!-- Project Header -->
    <header class="mb-8">
      <h1 class="text-5xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-base-content/70 mb-6">{description}</p>

      <div
        class="flex flex-wrap items-center gap-4 text-sm text-base-content/60 mb-6"
      >
        <span class="font-semibold">{formatPeriod(startDate, endDate)}</span>
        <span>•</span>
        <span>{calculateDuration(startDate, endDate)}</span>
        {
          !endDate && (
            <>
              <span>•</span>
              <span class="badge badge-success badge-sm">Ongoing</span>
            </>
          )
        }
      </div>

      <!-- Prominent Action Buttons -->
      {
        (demoLink || sourceLink) && (
          <div class="flex flex-wrap gap-3 mb-6">
            {demoLink && (
              <a
                href={demoLink}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary gap-2"
              >
                <ExternalLink class="size-5" />
                Live Demo
              </a>
            )}
            {sourceLink && (
              <a
                href={sourceLink}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-soft gap-2"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 32 32"
                  fill="currentColor"
                >
                  <path d="M16,2.345c7.735,0,14,6.265,14,14-.002,6.015-3.839,11.359-9.537,13.282-.7,.14-.963-.298-.963-.665,0-.473,.018-1.978,.018-3.85,0-1.312-.437-2.152-.945-2.59,3.115-.35,6.388-1.54,6.388-6.912,0-1.54-.543-2.783-1.435-3.762,.14-.35,.63-1.785-.14-3.71,0,0-1.173-.385-3.85,1.435-1.12-.315-2.31-.472-3.5-.472s-2.38,.157-3.5,.472c-2.677-1.802-3.85-1.435-3.85-1.435-.77,1.925-.28,3.36-.14,3.71-.892,.98-1.435,2.24-1.435,3.762,0,5.355,3.255,6.563,6.37,6.913-.403,.35-.77,.963-.893,1.872-.805,.368-2.818,.963-4.077-1.155-.263-.42-1.05-1.452-2.152-1.435-1.173,.018-.472,.665,.017,.927,.595,.332,1.277,1.575,1.435,1.978,.28,.787,1.19,2.293,4.707,1.645,0,1.173,.018,2.275,.018,2.607,0,.368-.263,.787-.963,.665-5.719-1.904-9.576-7.255-9.573-13.283,0-7.735,6.265-14,14-14Z" />
                </svg>
                View Source
              </a>
            )}
          </div>
        )
      }
    </header>

    <!-- Tech Stack Showcase -->
    {
      skills && skills.length > 0 && (
        <div class="card bg-base-200 mb-8">
          <div class="card-body">
            <h2 class="card-title text-lg mb-3">Tech Stack</h2>
            <div class="flex flex-wrap gap-2">
              {skills.map((skill) => (
                <SkillBadge skill={skill} />
              ))}
            </div>
          </div>
        </div>
      )
    }

    <!-- Divider -->
    <div class="divider"></div>

    <!-- Project Content -->
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <!-- Divider -->
    <div class="divider mt-12"></div>

    <!-- Back to projects link -->
    <div class="text-center mt-8">
      <a href="/projects" class="btn btn-primary"> View All Projects </a>
    </div>
  </article>

  <script is:inline>
    const imageOpenButton = document.querySelector("[data-project-image-open]");
    const imageDialog = document.querySelector("[data-project-image-dialog]");

    imageOpenButton?.addEventListener("click", () => {
      if (imageDialog instanceof HTMLDialogElement) {
        imageDialog.showModal();
      }
    });
  </script>
</Layout>
