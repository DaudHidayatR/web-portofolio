---
import { Image } from "astro:assets";
import SkillBadge from "../components/SkillBadge.astro";
import Layout from "./Layout.astro";

interface Props {
	title: string;
	seoTitle?: string;
	description: string;
	publishDate: Date;
	updatedDate?: Date;
	image: any;
	imageAlt?: string;
	imageWidth?: number;
	imageHeight?: number;
	tags?: string[];
}

const {
	title,
	seoTitle,
	description,
	publishDate,
	updatedDate,
	image,
	imageAlt,
	imageWidth = 1200,
	imageHeight = 630,
	tags,
} = Astro.props;
const pageTitle = seoTitle ?? title;
const featuredImageAlt = imageAlt ?? `${title} article featured image`;

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", {
		month: "long",
		day: "numeric",
		year: "numeric",
	});
}

// Calculate reading time (rough estimate based on word count)
const content = await Astro.slots.render("default");
const wordCount = content.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200); // Average reading speed: 200 words/min

// OG image URL for per-page social sharing
const origin = Astro.site?.origin ?? Astro.url.origin;
const ogImageUrl = image ? new URL(image.src, origin).href : undefined;
const canonicalUrl = new URL(Astro.url.pathname, origin).href;
const articleJsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": `${canonicalUrl}#webpage`,
			url: canonicalUrl,
			name: pageTitle,
			description,
			image: ogImageUrl,
			author: { "@id": `${origin}/#person` },
			about: tags ?? [],
		},
		{
			"@type": ["BlogPosting", "TechArticle"],
			"@id": `${canonicalUrl}#article`,
			headline: title,
			description,
			image: ogImageUrl,
			url: canonicalUrl,
			datePublished: publishDate.toISOString(),
			dateModified: (updatedDate ?? publishDate).toISOString(),
			author: { "@id": `${origin}/#person` },
			publisher: { "@id": `${origin}/#person` },
			keywords: tags ?? [],
			wordCount,
			inLanguage: "en",
		},
		{
			"@type": "Person",
			"@id": `${origin}/#person`,
			name: "Daud Hidayat Ramadhan",
			url: origin,
			jobTitle: "DevSecOps & Backend Engineer",
			sameAs: [
				"https://github.com/DaudHidayatR",
				"https://www.linkedin.com/in/daud-hidayat-ramadhan",
			],
		},
	],
};
---

<Layout
  title={pageTitle}
  description={description}
  ogImage={ogImageUrl}
  ogImageAlt={featuredImageAlt}
  ogImageWidth={imageWidth}
  ogImageHeight={imageHeight}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article class="max-w-4xl mx-auto px-4 py-20">
    <!-- Back button -->
    <div class="mb-8">
      <a href="/blog" class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to Blog
      </a>
    </div>

    <!-- Featured Image -->
    {image && (
      <figure class="mb-8 rounded-2xl overflow-hidden">
        <Image
          src={image}
          alt={featuredImageAlt}
          class="w-full aspect-video object-cover"
          width={imageWidth}
          height={imageHeight}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          data-image-component
        />
      </figure>
    )}

    <!-- Post Header -->
    <header class="mb-8">
      <h1 class="text-5xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-base-content/70 mb-4">{description}</p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-base-content/60">
        <time datetime={publishDate.toISOString()}>
          {formatDate(publishDate)}
        </time>
        <span>•</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span>•</span>
            <span>Updated: {formatDate(updatedDate)}</span>
          </>
        )}
      </div>

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <SkillBadge skill={tag} />
          ))}
        </div>
      )}
    </header>

    <!-- Divider -->
    <div class="divider"></div>

    <!-- Post Content -->
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <!-- Divider -->
    <div class="divider mt-12"></div>

    <!-- Back to blog link -->
    <div class="text-center mt-8">
      <a href="/blog" class="btn btn-primary">
        View All Posts
      </a>
    </div>
  </article>
</Layout>
